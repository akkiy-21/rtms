# PostgreSQL
POSTGRES_USER=mmi
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=mmi_scada
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SQLAlchemy
DATABASE_URL=postgresql+psycopg://mmi:change-this-db-password@postgres:5432/mmi_scada

# RTMS auth
RTMS_JWT_SECRET=change-this-to-a-long-random-secret
RTMS_INITIAL_ADMIN_ID=admin
RTMS_INITIAL_ADMIN_NAME=初期管理者
RTMS_INITIAL_ADMIN_PASSWORD=change-this-admin-password

# Backend runtime
RTMS_DEBUG=false
RTMS_CORS_ORIGINS=*
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=4

# Redis / Celery
RTMS_REDIS_URL=redis://redis:6379/0
RTMS_CELERY_BROKER_URL=redis://redis:6379/0
RTMS_CELERY_RESULT_BACKEND=redis://redis:6379/0

# MQTT
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_WEBSOCKET_PORT=9001